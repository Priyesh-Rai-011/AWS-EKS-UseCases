    {
      "id": "principles_t", "type": "text", "x": 910, "y": 872, "width": 370, "height": 216,
      "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 1,
      "opacity": 100, "groupIds": [], "frameId": null, "roundness": null,
      "seed": 323, "version": 1, "versionNonce": 323, "isDeleted": false,
      "boundElements": null, "updated": 1, "link": null, "locked": false,
      "text": "3 Core Principles:\n\n1. Nothing sensitive in git\n   Only ExternalSecret pointers commit\n\n2. Single source of truth\n   Rotate in AWS SM → ESO propagates\n   to ALL clusters via refreshInterval\n\n3. Separation of concerns\n   ArgoCD: app lifecycle\n   ESO: secret lifecycle\n   Pods: zero AWS awareness", "fontSize": 14, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top", "baseline": 12,
      "containerId": null, "originalText": "3 Core Principles:\n\n1. Nothing sensitive in git\n   Only ExternalSecret pointers commit\n\n2. Single source of truth\n   Rotate in AWS SM → ESO propagates\n   to ALL clusters via refreshInterval\n\n3. Separation of concerns\n   ArgoCD: app lifecycle\n   ESO: secret lifecycle\n   Pods: zero AWS awareness", "lineHeight": 1.5
    }
